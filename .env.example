# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_bot_client_id

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/autoclaim-bot

# Scheduler Settings (24-hour format, UTC+8 timezone)
# Default: 00:00 AM UTC+8 (midnight)
CLAIM_HOUR=0
CLAIM_MINUTE=0

# Crunchyroll Configuration
CR_EMAIL=your_crunchyroll_email
CR_PASSWORD=your_crunchyroll_password

# U2 BDMV Torrent Feed
# Full RSS URL including passkey from https://u2.dmhy.org/torrentrss.php
# Example: https://u2.dmhy.org/torrentrss.php?rows=50&cat16=1&icat=1&ismalldescr=1&isize=1&iuplder=1&trackerssl=1&passkey=your_passkey_here
U2_RSS_URL=
